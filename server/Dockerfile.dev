# Debian slim (not alpine): onnxruntime-node (embeddings) ships glibc-only binaries
FROM node:20-slim

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy prisma schema and generate client
COPY prisma ./prisma/
RUN npx prisma generate

# Copy source code
COPY . .

EXPOSE 3010

# Regenerate client (build-time layer may be cached against an older schema),
# run migrations, then start dev server
CMD npx prisma generate --schema=./prisma/schema.prisma && npx prisma migrate deploy --schema=./prisma/schema.prisma && npm run dev
