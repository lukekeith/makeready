{
  "name": "makeready-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/advertise-bonjour.cjs & tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "build:prod": "prisma generate && tsc && cp -r src/generated dist/ && cp -r public dist/",
    "build:only": "tsc",
    "start": "node dist/scripts/load-themes.js && node dist/index.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --coverage --reporter=verbose --exclude='test/integration/production.test.ts'",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:prod": "vitest run test/integration/production.test.ts",
    "test:prod:watch": "vitest test/integration/production.test.ts",
    "themes:load": "tsx src/scripts/load-themes.ts",
    "db:ensure-session": "tsx scripts/ensure-session-table.ts",
    "db:local:start": "docker-compose -f docker-compose.local.yml up -d",
    "db:local:stop": "docker-compose -f docker-compose.local.yml down",
    "db:setup:local": "npm run db:local:start && sleep 3 && npx prisma migrate deploy && npm run db:seed:dev",
    "db:seed:dev": "npx tsx prisma/seed-dev.ts",
    "postmigrate": "npm run db:ensure-session",
    "docs:validate": "tsx scripts/validate-openapi.ts",
    "schema:validate": "tsx scripts/schema/validate-schema.ts",
    "schema:generate": "tsx scripts/schema/yaml-to-hcl.ts && tsx scripts/schema/yaml-to-prisma.ts",
    "schema:diff": "npm run schema:generate && dotenv -- bash -c 'cd atlas && ../bin/atlas migrate diff --env local'",
    "migrate:apply": "dotenv -- bash -c 'cd atlas && ../bin/atlas migrate apply --env local'",
    "migrate:status": "dotenv -- bash -c 'cd atlas && ../bin/atlas migrate status --env local'",
    "db:seed": "tsx scripts/schema/run-seeds.ts",
    "db:seed:prod": "tsx scripts/schema/run-seeds.ts --env=production",
    "templates:import": "npx tsx scripts/import-templates.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.991.0",
    "@parse/node-apn": "^6.5.0",
    "@prisma/client": "^6.18.0",
    "@types/express-session": "^1.18.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/qrcode": "^1.5.6",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exif-reader": "^2.0.3",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "twilio": "^5.10.4",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-signature": "^1.1.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-serve-static-core": "5.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.1",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@vitest/coverage-v8": "^2.1.8",
    "bonjour": "^3.5.0",
    "dotenv-cli": "^11.0.0",
    "shadcn": "^3.5.0",
    "supertest": "^7.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
