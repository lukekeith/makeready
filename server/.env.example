PORT=3001
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Session Secret
SESSION_SECRET=your_secret_key_here

# Client URL
CLIENT_URL=http://localhost:5173

# Database (Railway Postgres with pgvector)
DATABASE_URL="postgresql://user@localhost:5432/makeready?schema=public"
DIRECT_URL="postgresql://user@localhost:5432/makeready?schema=public"

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_ID=your_verify_service_id_here
TWILIO_PHONE_NUMBER=+1234567890

# Cloudflare R2 Storage Configuration (S3-compatible)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=makeready-media
R2_PUBLIC_URL=https://images.makeready.org

# Cloudflare Stream Configuration (for video uploads)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Apple Push Notification Service (APNs) Configuration
APNS_KEY_ID=your_key_id_here
APNS_TEAM_ID=your_team_id_here
APNS_BUNDLE_ID=com.makeready.app
APNS_KEY_PATH=./certs/AuthKey_XXXXXXXXXX.p8
APNS_ENVIRONMENT=production

# Semantic Bible Search (pgvector + local embedding model)
# EMBEDDINGS_ENABLED=false disables concept search (falls back to API.Bible keyword search)
EMBEDDINGS_ENABLED=true
# onnxruntime execution provider: cpu (default), coreml, webgpu — requires glibc (not alpine)
EMBEDDINGS_DEVICE=cpu
# Model weight cache dir (baked into Docker image at /app/.hf-cache)
#HF_CACHE_DIR=./.hf-cache
# Warm the model after boot so the first query is fast (recommended on Railway)
EMBEDDINGS_WARMUP=true
# Minimum cosine similarity for a verse match (bge scores compress into ~0.5-0.85)
SEMANTIC_SIM_THRESHOLD=0.6
