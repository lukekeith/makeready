  selections           Json? // Array of styled text spans with start, end, style
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  lessonActivity       LessonActivity? @relation(fields: [lessonActivityId], references: [id], onDelete: Cascade)
  scheduledActivity    ScheduledLessonActivity? @relation(fields: [scheduledActivityId], references: [id], onDelete: Cascade)
  sourceReference      ActivitySourceReference? @relation(fields: [sourceReferenceId], references: [id], onDelete: SetNull)
  theme                TextTheme? @relation(fields: [themeId], references: [id], onDelete: SetNull)
  exegesisHighlights   ExegesisHighlight[]
  @@index([lessonActivityId])
  @@index([scheduledActivityId])
  @@index([themeId])
  @@map("activity_read_blocks")
}

model ExegesisHighlight {
  id                   String @id @default(uuid())
  readBlockId          String // FK to ActivityReadBlock (locked scripture block) that this highlight applies to
  orderNumber          Int // Stable ordering for highlight navigation
  start                Int // Start character offset (plain-text) into the block content
  end                  Int // End character offset (exclusive)
  noteMarkdown         String @db.Text // Leader-authored markdown shown to members when they open the highlight
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  readBlock            ActivityReadBlock @relation(fields: [readBlockId], references: [id], onDelete: Cascade)

  @@unique([readBlockId, orderNumber])
  @@unique([readBlockId, start, end])
  @@index([readBlockId])
  @@index([readBlockId, orderNumber])
  @@map("exegesis_highlights")
}

model FaqItem {
  id                   String @id @default(uuid())
  scope                String // Page or surface where this FAQ is rendered (home, for-leaders, for-members, about, join-beta)
  question             String
  answer               String @db.Text
  sortOrder            Int @default(0)
  isActive             Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([scope, question])
  @@index([scope])
  @@index([scope, isActive])
  @@index([scope, sortOrder])
  @@map("faq_items")
}

model BetaApplication {
  id                   String @id @default(uuid())
  microsoftId          String @unique // Microsoft Entra ID object ID or subject for the authenticated applicant
  applicantEmail       String @unique
  applicantName        String
  applicantPicture     String?
  phoneNumber          String?
  organizationName     String
  organizationWebsite  String?
  groupMemberAgeRange  String
  numberOfGroups       Int
  estimatedGroupMembers Int
  groupDescription     String @db.Text
  status               BetaApplicationStatus @default(PENDING)
  userId               String?
  organizationId       String?
  reviewNotes          String? @db.Text
  reviewedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([organizationId])
  @@index([microsoftId])
  @@index([applicantEmail])
  @@map("beta_applications")
}

model ActivityLog {
  id                   String @id @default(uuid())
  category             LogCategory
  activityType         String // e.g., AUTH_GOOGLE_LOGIN, JOIN_GROUP_REQUEST
  status               LogStatus
  userId               String? // User ID for User-authenticated actions
  memberId             String? // Member ID for Member-authenticated actions
  actorIp              String? // IP address for rate-limiting/security
  userAgent            String? // For device tracking
  route                String // e.g., /auth/google/callback
  method               String // HTTP method: GET, POST, etc.
  groupId              String?
  eventId              String?
  enrollmentId         String?
  lessonId             String?
  organizationId       String?
  inviteId             String?
  message              String // Human-readable log message
  errorCode            String? // Error code if status is FAILURE
  errorMessage         String? // Error message if status is FAILURE
  warningMessage       String? // Warning message if status is WARNING
  metadata             Json? // Additional structured data
  createdAt            DateTime @default(now())
  @@index([category])
  @@index([activityType])
  @@index([status])
  @@index([userId])
  @@index([memberId])
  @@index([groupId])
  @@index([createdAt])
  @@index([category, createdAt])
  @@index([activityType, status])
  @@map("activity_logs")
}

model ApiKey {
  id                   String @id @default(uuid())
  keyHash              String @unique // SHA-256 hash of full key (irreversible)
  keyPrefix            String // First 8 chars for display (e.g., mr_abc12)
  name                 String // Friendly name (e.g., 'Claude Code')
  description          String?
  userId               String
  isActive             Boolean @default(true)
  expiresAt            DateTime?
  lastUsedAt           DateTime?
  usageCount           Int @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([keyPrefix])
  @@map("api_keys")
}

model PreviewToken {
  id                   String @id @default(uuid())
  token                String @unique // The preview token string passed as ?preview_token=xxx
  userId               String @unique // One token per user — upsert replaces the old one
  organizationId       String // Org scope — any leader in this org can preview any org content
  createdAt            DateTime @default(now())

  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  previewStates        PreviewState[]
  @@index([token])
  @@index([userId])
  @@map("preview_tokens")
}

model PreviewState {
  id                   String @id @default(uuid())
  previewTokenId       String // FK to PreviewToken — cascade-deletes when token is replaced
  entityType           String // note | video_progress | exegesis_visit
  activityId           String // The lesson activity this state is for
  data                 Json // Saved state (note content, video seconds, visited highlight IDs)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  previewToken         PreviewToken @relation(fields: [previewTokenId], references: [id], onDelete: Cascade)
  @@unique([previewTokenId, entityType, activityId])
  @@map("preview_state")
}

model Notification {
  id                   String @id @default(uuid())
  userId               String
  type                 String // JOIN_REQUEST, MEMBER_JOINED
  title                String
  body                 String
  isRead               Boolean @default(false)
  data                 Json?
  dedupeKey            String? // Coalescing key (e.g. 'program-updates:{enrollmentId}'): while an unread notification with this key exists, new events update it in place instead of inserting
  actions              Json? // Array of {label, view, params} action descriptors; clients resolve 'view' to a compact in-modal view (e.g. enrollment sync settings)
  createdAt            DateTime @default(now())

  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, dedupeKey])
  @@map("notifications")
}

model Activity {
  id                   String @id @default(uuid())
  actorId              String // User who performed the action
  action               ActivityAction
  resourceType         String // GROUP, PROGRAM, LESSON, EVENT, POST, ENROLLMENT, TEMPLATE, MEMBER
  resourceId           String // UUID of affected resource (polymorphic, no FK)
  resourceName         String // Denormalized display name for feed rendering
  organizationId       String? // For scoping feed to an org
  groupId              String? // Group context for group-level feeds
  targetUserId         String? // Target user for directed/notification activities
  title                String? // Display title (for notification-style activities)
  body                 String? @db.Text // Display body (for notification-style activities)
  isRead               Boolean @default(false) // Read status for targeted activities
  metadata             Json? // Extra context (changed fields, etc.)
  createdAt            DateTime @default(now())

  actor                User @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  group                Group? @relation("ActivityGroup", fields: [groupId], references: [id], onDelete: SetNull)
  targetUser           User? @relation("ActivityTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  @@index([actorId, createdAt])
  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([groupId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetUserId, isRead])
  @@map("activities")
}

model MembershipEvent {
  id                   String @id @default(uuid())
  memberId             String // The member this event concerns (canonical identity)
  groupId              String? // Group context; null for org-level events
  organizationId       String? // Org context for org-scoped history queries
  action               MembershipEventAction
  actorId              String? // Who performed it — User id (leader) or Member id (self). Polymorphic, no FK.
  actorType            String? // user, member, or system — disambiguates actorId
  note                 String? @db.Text // Optional reason/message (e.g. rejection reason, join message)
  metadata             Json? // Extra context (requestId, role, source, etc.)
  createdAt            DateTime @default(now())

  member               Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  group                Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  @@index([memberId, createdAt])
  @@index([groupId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("membership_events")
}

model SmsCampaign {
  id                   String @id @default(uuid())
  slug                 String @unique // Lookup key, e.g. group-invite, study-invite
  name                 String // Human-readable campaign name
  description          String? @db.Text
  messagingServiceSid  String? // Twilio Messaging Service SID (MG...) override. Falls back to TWILIO_MESSAGING_SERVICE_SID env var.
  isActive             Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  templates            SmsTemplate[]
  @@map("sms_campaigns")
}

model SmsTemplate {
  id                   String @id @default(uuid())
  campaignId           String
  slug                 String @unique // Lookup key, e.g. group-invite-v1
  body                 String @db.Text // Template with {variable} placeholders
  requiredProps        Json // JSON array of required context keys for rendering
  minIntervalMinutes   Int @default(1200) // Min minutes between re-sends to the same phone (default 20hrs)
  isActive             Boolean @default(true)
  version              Int @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  campaign             SmsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  logs                 SmsLog[]
  @@index([campaignId])
  @@map("sms_templates")
}

model SmsLog {
  id                   String @id @default(uuid())
  templateId           String
  recipientPhone       String // E.164 phone number
  messageBody          String @db.Text // The actual rendered message that was sent
  twilioMessageSid     String?
  status               SmsDeliveryStatus @default(QUEUED)
  statusUpdatedAt      DateTime?
  sentById             String?
  metadata             Json? // Context data like groupId, enrollmentId
  isDevSend            Boolean @default(false)
  errorMessage         String?
  createdAt            DateTime @default(now())

  template             SmsTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sentBy               User? @relation("SmsSender", fields: [sentById], references: [id], onDelete: SetNull)
  @@index([templateId, recipientPhone, createdAt])
  @@index([recipientPhone])
  @@index([status])
  @@index([twilioMessageSid])
  @@map("sms_logs")
}

model TwilioCallback {
  id                   String @id @default(uuid())
  callbackType         String? // Best-effort Twilio callback category, e.g. trust_hub, business_profile, app
  accountSid           String? // Twilio Account SID associated with the callback
  resourceSid          String? // Best-effort SID for the affected Twilio resource
  eventType            String? // Best-effort Twilio event or status value
  payload              Json // Full Twilio callback payload
  receivedAt           DateTime @default(now())
  @@index([receivedAt])
  @@index([accountSid])
  @@index([resourceSid])
  @@index([eventType])
  @@map("twilio_callbacks")
}
