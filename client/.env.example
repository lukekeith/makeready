APP_NAME=MakeReady
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.makeready.org

LOG_CHANNEL=dated
LOG_LEVEL=info
# LOG_VERBOSE=true logs every user action; false logs only warnings/errors.
LOG_VERBOSE=false
LOG_RETENTION_DAYS=30

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

API_URL=https://api.makeready.org

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.makeready.org/admin/auth/google/callback
