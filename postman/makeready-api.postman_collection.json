          "name": "Public QR Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/qrcode?url=https://makeready.app&size=400&includeLogo=true&color=%236c47ff&bg=%23ffffff",
              "host": ["{{baseUrl}}"],
              "path": ["public", "qrcode"],
              "query": [
