                },
                {
                  "key": "color",
                  "value": "%236c47ff",
                  "description": "Hex color for QR pixels (default: #6c47ff)"
                },
                {
                  "key": "bg",
                  "value": "%23ffffff",
                  "description": "Hex color for background (default: #ffffff)"
                }
              ]
            },
            "description": "Generate QR code for any URL - PUBLIC ENDPOINT (returns PNG image)"
          }
        }
